# Environment Configuration
# Copy this file to .env and update with your configuration

# Application Mode
# This is a frontend-only application - all analysis runs in the browser
VITE_APP_MODE=frontend

# Optional: Backend server URL for server-side analysis execution.
# When set, tools that support backend execution will show a mode selector.
# The frontend works fully offline when the backend is unavailable.
VITE_BACKEND_URL=http://localhost:8000

# Optional: Mapbox access token for the satellite / hybrid base map.
# Without it, the satellite base map is disabled; all other base maps still work.
# Either variable is accepted; VITE_MAPBOX_API_KEY takes precedence.
VITE_MAPBOX_API_KEY=
# VITE_MAPBOX_TOKEN=
